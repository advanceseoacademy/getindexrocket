generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String              @id @default(cuid())
  email              String              @unique
  name               String?
  password           String?
  googleId           String?             @unique
  role               String              @default("user")
  creditBalance      Int                 @default(0)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  sessions           Session[]
  tasks              Task[]
  creditTransactions CreditTransaction[]
  paymentEvents      PaymentEvent[]
  memberships        Membership[]
  blogPosts          BlogPost[]
  supportTickets     SupportTicket[]
  signupDevice       SignupDevice?
}

/** One signup per browser/device (and IP cooldown) to stop free-credit abuse. */
model SignupDevice {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceHash String   @unique
  ipHash     String?
  createdAt  DateTime @default(now())

  @@index([ipHash, createdAt])
}

model PaymentEvent {
  id           String   @id @default(cuid())
  externalId   String   @unique
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  email        String
  amountUsd        Float
  creditsAdded     Int
  intendedCredits  Int      @default(0)
  planId           String?
  eventType    String?
  provider     String   @default("buymeacoffee")
  createdAt    DateTime @default(now())

  @@index([email, createdAt])
  @@index([userId, createdAt])
}

model Membership {
  id                 String    @id @default(cuid())
  externalSubId      String    @unique
  userId             String?
  user               User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  email              String
  levelName          String?
  levelId            String?
  status             String    @default("active")
  amountUsd          Float     @default(0)
  paused             Boolean   @default(false)
  cancelAtPeriodEnd  Boolean   @default(false)
  canceledAt         DateTime?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([email])
  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Task {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  externalId        String?   @unique
  providerTaskId    String?
  tier              String    @default("standard")
  status            String    @default("pending")
  smartVerification Boolean   @default(false)
  urlsCount         Int       @default(0)
  creditsCharged    Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  urls              TaskUrl[]

  @@index([userId, createdAt])
}

model TaskUrl {
  id          String    @id @default(cuid())
  taskId      String
  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  url         String
  status      String    @default("pending")
  hubToken    String?   @unique
  indexNowAt  DateTime?
  botHitAt    DateTime?
  botHitCount Int       @default(0)
  attempts    Int       @default(0)
  nextRunAt   DateTime?
  lastError   String?
  verifiedAt  DateTime?
  indexedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([taskId])
  @@index([status, nextRunAt])
  @@index([hubToken])
}

model CreditTransaction {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount       Int
  balanceAfter Int
  type         String
  description  String?
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
}

model BlogPost {
  id              String    @id @default(cuid())
  slug            String    @unique
  title           String
  excerpt         String?
  featuredImageUrl String?
  content         String    @db.Text
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?
  status          String    @default("draft")
  publishedAt     DateTime?
  authorId        String?
  author          User?     @relation(fields: [authorId], references: [id], onDelete: SetNull)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status, publishedAt])
}

model SupportTicket {
  id        String          @id @default(cuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject   String
  status    String          @default("open")
  priority  String          @default("normal")
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  messages  TicketMessage[]

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model TicketMessage {
  id        String        @id @default(cuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId  String?
  body      String        @db.Text
  isStaff   Boolean       @default(false)
  createdAt DateTime      @default(now())

  @@index([ticketId, createdAt])
}
