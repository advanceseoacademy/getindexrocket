# Copy to .env on VPS — never commit real secrets
#
# IMPORTANT — two URLs required for Supabase:
#   DATABASE_URL  → port 6543 (pooler, for app runtime)
#   DIRECT_URL    → port 5432 (direct/session, for migrations ONLY)
# Migrations HANG if DIRECT_URL is missing or uses port 6543.

DATABASE_URL=postgresql://postgres.PROJECT:PASSWORD@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.PROJECT:PASSWORD@aws-0-ap-northeast-2.pooler.supabase.com:5432/postgres

NEXT_PUBLIC_APP_URL=https://getindexrocket.com

# Google Analytics (gtag.js)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-4XGS16ECPT

# Supabase (optional client + management API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_ACCESS_TOKEN=

GETINDEXROCKET_PORT=3005

# Self-hosted backlink indexer
# Generate a random 32-char hex key; served at /indexnow/{INDEXNOW_KEY}.txt
INDEXNOW_KEY=
CRON_SECRET=
# Optional: separate origin for hub pages (defaults to NEXT_PUBLIC_APP_URL)
# INDEXER_HUB_ORIGIN=https://getindexrocket.com
#
# Bing Webmaster Tools → Settings → API Access → Generate API key
# Site must be verified at https://www.bing.com/webmasters
BING_WEBMASTER_API_KEY=
BING_WEBMASTER_SITE_URL=https://getindexrocket.com
#
# Azure Bing Web Search API — optional Smart Verification fallback
# BING_SEARCH_API_KEY=
#
# Google Programmable Search — Smart Verification (checks Google index; preferred)
# Create at https://programmablesearchengine.google.com/ (search entire web)
# GOOGLE_CSE_API_KEY=
# GOOGLE_CSE_CX=
#
# Google Indexing API + Search Console sitemap (hub pages on your domain)
# 1. GCP service account + enable Indexing API + Search Console API
# 2. Add service account email as Owner in Google Search Console
# GOOGLE_INDEXING_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# GOOGLE_SEARCH_CONSOLE_SITE_URL=https://getindexrocket.com/
# INDEXER_REFUND_DAYS=15

# Legacy (no longer used — kept for reference during migration)
# INDEXNOWFAST_API_KEY=
# INDEXNOWFAST_API_URL=https://www.indexnowfast.com/api/v1

NEXT_PUBLIC_BMC_USERNAME=
NEXT_PUBLIC_BMC_MEMBERSHIP_URL=
BMC_WEBHOOK_SECRET=

SESSION_SECRET=

NEXT_PUBLIC_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

ADMIN_EMAILS=your@email.com
